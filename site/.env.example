# Sanity — public (safe to expose; used by the browser and Studio).
# These values match the committed public defaults. Override them only for another Sanity project.
NEXT_PUBLIC_SANITY_PROJECT_ID=gtq6sx9w
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-06-01
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity — server-only read token (optional until Session 05 draft preview).
# Create in sanity.io/manage → API → Tokens (Viewer role). Never prefix it NEXT_PUBLIC_.
SANITY_API_READ_TOKEN=

# Sanity — webhook signature secret for /api/revalidate.
# Use a long random value and configure the same value in Sanity webhooks.
SANITY_REVALIDATE_SECRET=
